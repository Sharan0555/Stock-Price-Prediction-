"use client";

import { useCallback, useEffect, useRef, useState } from "react";
import { useRouter } from "next/navigation";
import TickerCard from "@/components/TickerCard";
import { fetchJsonWithFallback } from "@/lib/api-base";

type QuoteResponse = {
  symbol: string;
  quote: {
    c: number;
    h: number;
    l: number;
    o: number;
    pc: number;
  };
};

type HistoryResponse = {
  symbol: string;
  source: string;
  series: Array<{ t: number; c: number }>;
};

type PopularStock = {
  symbol: string;
  name: string;
  market: "US" | "NSE";
  currency: "USD" | "INR";
  apiSymbol?: string;
};

type PopularPrediction = PopularStock & {
  price?: number;
  predictedPrice?: number;
  changePct?: number;
  signal?: "BUY" | "SELL" | "HOLD";
  confidence?: number;
  error?: string;
  loading?: boolean;
};

interface StockPrice {
  sym: string;
  name: string;
  currency: "USD" | "INR";
  exchange: string;
  price: number;
  prev: number;
  chg: number;
  up: boolean;
  market_open: boolean;
}

const POPULAR_STOCKS_PREVIEW: PopularStock[] = [
  { symbol: "AAPL", name: "Apple", market: "US", currency: "USD" },
  { symbol: "MSFT", name: "Microsoft", market: "US", currency: "USD" },
  { symbol: "RELIANCE", name: "Reliance Industries", market: "NSE", currency: "INR", apiSymbol: "RELIANCE.NS" },
  { symbol: "TCS", name: "TCS", market: "NSE", currency: "INR", apiSymbol: "TCS.NS" },
  { symbol: "AMZN", name: "Amazon", market: "US", currency: "USD" },
  { symbol: "NVDA", name: "NVIDIA", market: "US", currency: "USD" },
  { symbol: "ITC", name: "ITC", market: "NSE", currency: "INR", apiSymbol: "ITC.NS" },
  { symbol: "HDFCBANK", name: "HDFC Bank", market: "NSE", currency: "INR", apiSymbol: "HDFCBANK.NS" },
];

const formatCurrency = (value: number, currency?: string) => {
  const safeCurrency = currency === "INR" ? "INR" : "USD";
  try {
    return new Intl.NumberFormat("en-IN", {
      style: "currency",
      currency: safeCurrency,
      maximumFractionDigits: 2,
    }).format(value);
  } catch {
    const symbol = safeCurrency === "INR" ? "Rs" : "$";
    return `${symbol}${value.toFixed(2)}`;
  }
};

const formatPct = (value: number) => {
  const sign = value > 0 ? "+" : value < 0 ? "" : "";
  return `${sign}${value.toFixed(2)}%`;
};

const clamp = (value: number, min: number, max: number) =>
  Math.min(max, Math.max(min, value));

const buildSparkBars = (key: string) => {
  let seed = 0;
  for (let i = 0; i < key.length; i += 1) {
    seed = (seed * 31 + key.charCodeAt(i)) % 97;
  }
  return Array.from({ length: 6 }, (_, index) => {
    const base = 35 + ((seed + index * 17) % 45);
    return base;
  });
};

const computeBaselinePrediction = (series: number[]) => {
  if (!series.length) return undefined;
  if (series.length < 2) return series[series.length - 1];
  const returns = series.slice(1).map((val, idx) => {
    const prev = series[idx];
    return prev ? (val - prev) / prev : 0;
  });
  const window = Math.min(20, returns.length);
  const windowReturns = returns.slice(-window);
  const mean =
    windowReturns.reduce((acc, val) => acc + val, 0) / Math.max(windowReturns.length, 1);
  const clipped = Math.min(0.02, Math.max(-0.02, mean));
  const last = series[series.length - 1];
  return last * (1 + clipped);
};

const computeTrendPct = (series: number[]) => {
  if (series.length < 15) return 0;
  const start = series[series.length - 15];
  const end = series[series.length - 1];
  return start ? ((end - start) / start) * 100 : 0;
};

type SparkBarsProps = {
  symbol: string;
  price?: number;
  up: boolean;
  animate: boolean;
  signal: "BUY" | "SELL" | "HOLD";
};

type PopularStockCardProps = {
  item: PopularPrediction;
  live?: StockPrice;
  isOpen: boolean;
  sparkPrice?: number;
  flashDirection?: "up" | "down";
};

const buildLiveSparkBars = (symbol: string, price?: number, up: boolean = true) => {
  if (typeof price !== "number" || Number.isNaN(price)) {
    return buildSparkBars(symbol);
  }

  const seedBars = buildSparkBars(`${symbol}-${Math.round(price * 100)}-${up ? "up" : "down"}`);
  const trendTilt = up ? 1 : -1;

  return seedBars.map((height, index) =>
    clamp(height + trendTilt * (index - 2) * 4, 22, 100),
  );
};

function SparkBars({ symbol, price, up, animate, signal }: SparkBarsProps) {
  const bars = buildLiveSparkBars(symbol, price, up);
  const priceKey =
    typeof price === "number" && !Number.isNaN(price)
      ? Math.round(price * 100)
      : "fallback";

  return (
    <div className="sparkline">
      {bars.map((height, index) => (
        <span
          key={`${symbol}-${priceKey}-${animate ? "live" : "closed"}-${index}`}
          className={`spark-bar ${signal === "SELL" ? "sell" : "buy"}`}
          style={{
            height: `${height}%`,
            animation: animate
              ? `spark-bounce 0.9s ease-out ${index * 0.08}s 1 both`
              : "none",
          }}
        />
      ))}
    </div>
  );
}

function PopularStockCard({
  item,
  live,
  isOpen,
  sparkPrice,
  flashDirection,
}: PopularStockCardProps) {
  const chg = live?.chg ?? 0;
  const up = live?.up ?? chg >= 0;
  const currency = live?.currency ?? item.currency;
  const exchange = live?.exchange ?? (item.market === "NSE" ? "NSE" : "NYSE");
  const displayPrice = live?.price ?? item.price;
  
  // Calculate predicted price and signal
  const predictedPrice = displayPrice ? displayPrice * (1 + (chg / 100) * 1.5) : undefined;
  const signal: "BUY" | "SELL" | "HOLD" = chg > 0.3 ? "BUY" : chg < -0.3 ? "SELL" : "HOLD";
  
  const badgeClass =
    signal === "BUY"
      ? "bg-emerald-100 text-emerald-700"
      : signal === "SELL"
      ? "bg-red-100 text-red-700"
      : "bg-[var(--paper-strong)] text-[var(--ink-muted)]";
  
  const formattedPrice =
    displayPrice !== undefined
      ? currency === "USD"
        ? `$${displayPrice.toFixed(2)}`
        : `₹${displayPrice.toLocaleString("en-IN", {
            minimumFractionDigits: 2,
            maximumFractionDigits: 2,
          })}`
      : "—";
  
  const formattedChg = `${up ? "+" : ""}${chg.toFixed(2)}%`;
  const flashColor =
    flashDirection === "up"
      ? "#2e7d32"
      : flashDirection === "down"
      ? "#c62828"
      : "#1a0f00";
  const changeColor = up ? "#2e7d32" : "#c62828";

  return (
    <div
      key={item.symbol}
      className="tilt-card popular-card rounded-2xl border border-[var(--border)] p-4 shadow-sm"
    >
      <div className="popular-sheen" aria-hidden="true" />
      <div className="relative z-10 flex items-start justify-between gap-3">
        <div>
          <div className="text-sm font-semibold text-[var(--ink)]">{item.name}</div>
          <div
            className="mt-1"
            style={{ display: "flex", alignItems: "center", gap: 6 }}
          >
            <span className="text-xs text-[var(--ink-muted)]">
              {item.symbol} · {exchange}
            </span>
            <span
              style={{
                fontSize: 9,
                fontFamily: "monospace",
                letterSpacing: 0.5,
                fontWeight: 700,
                padding: "2px 8px",
                borderRadius: 10,
                color: isOpen ? "#2e7d32" : "#888",
                background: isOpen ? "rgba(46,125,50,0.08)" : "rgba(0,0,0,0.04)",
                border: `0.5px solid ${
                  isOpen ? "rgba(46,125,50,0.3)" : "rgba(0,0,0,0.1)"
                }`,
              }}
            >
              {isOpen ? "● LIVE" : "● CLOSED"}
            </span>
          </div>
        </div>
        <span className={`rounded-full px-3 py-1 text-xs font-semibold ${badgeClass}`}>
          {signal}
        </span>
      </div>

      <div className="relative z-10 mt-4 grid grid-cols-2 gap-3 text-sm">
        <div>
          <div className="text-[10px] uppercase tracking-[0.2em] text-[var(--ink-muted)]">
            Price
          </div>
          <div
            className="mt-1"
            style={{
              color: flashColor,
              transition: "color 0.4s ease",
              fontWeight: 800,
              fontSize: 22,
              fontFamily: "system-ui",
            }}
          >
            {formattedPrice}
          </div>
          <div
            className="mt-1 inline-flex w-fit rounded-full px-2 py-1 text-[11px]"
            style={{
              color: changeColor,
              background: up ? "rgba(46,125,50,0.08)" : "rgba(198,40,40,0.08)",
              transition: "color 0.3s, background 0.3s",
            }}
          >
            {formattedChg}
          </div>
        </div>
        <div>
          <div className="text-[10px] uppercase tracking-[0.2em] text-[var(--ink-muted)]">
            Prediction
          </div>
          <div className="mt-1 text-base font-semibold text-[var(--ink)]">
            {predictedPrice !== undefined
              ? formatCurrency(predictedPrice, currency)
              : "—"}
          </div>
          <div
            className={`text-[11px] ${
              chg >= 0 ? "text-emerald-700" : "text-red-700"
            }`}
          >
            {formatPct(chg * 1.5)}
          </div>
        </div>
      </div>

      <div className="relative z-10 mt-3 flex items-end justify-between gap-4">
        <SparkBars
          symbol={item.symbol}
          price={sparkPrice}
          up={up}
          animate={isOpen}
          signal={signal}
        />
        <div className="text-[11px] text-[var(--ink-muted)]">
          {Math.round(70 + Math.abs(chg * 1.5) * 2)}%
        </div>
      </div>
    </div>
  );
}

export default function Home() {
  const router = useRouter();
  const [popularPredictions, setPopularPredictions] = useState<PopularPrediction[]>(
    POPULAR_STOCKS_PREVIEW.map((stock) => ({ ...stock, loading: true })),
  );
  const [popularLoading, setPopularLoading] = useState(false);
  const [popularError, setPopularError] = useState<string | null>(null);
  const [livePrices, setLivePrices] = useState<Record<string, StockPrice>>({});
  const [sparkPrices, setSparkPrices] = useState<Record<string, number>>({});
  const [priceFlash, setPriceFlash] = useState<Record<string, "up" | "down">>({});
  const marketStatusRef = useRef<Record<string, boolean>>({});
  const livePricesRef = useRef<Record<string, StockPrice>>({});
  const sparkPricesRef = useRef<Record<string, number>>({});
  const flashTimeoutsRef = useRef<Record<string, number>>({});

  const queuePriceFlash = useCallback((
    symbol: string,
    nextPrice: number | undefined,
    previousPrice?: number,
  ) => {
    if (
      typeof nextPrice !== "number" ||
      Number.isNaN(nextPrice) ||
      previousPrice === undefined ||
      nextPrice === previousPrice
    ) {
      return;
    }

    const direction = nextPrice > previousPrice ? "up" : "down";
    if (flashTimeoutsRef.current[symbol] !== undefined) {
      window.clearTimeout(flashTimeoutsRef.current[symbol]);
    }

    setPriceFlash((current) => ({ ...current, [symbol]: direction }));
    flashTimeoutsRef.current[symbol] = window.setTimeout(() => {
      setPriceFlash((current) => {
        const next = { ...current };
        delete next[symbol];
        return next;
      });
      delete flashTimeoutsRef.current[symbol];
    }, 400);
  }, []);

  useEffect(() => {
    const handleMove = (event: PointerEvent) => {
      const { innerWidth, innerHeight } = window;
      const offsetX = (event.clientX / innerWidth - 0.5) * 16;
      const offsetY = (event.clientY / innerHeight - 0.5) * 16;
      document.documentElement.style.setProperty("--px", `${offsetX}px`);
      document.documentElement.style.setProperty("--py", `${offsetY}px`);
    };

    const handleScroll = () => {
      document.documentElement.style.setProperty(
        "--scrollY",
        `${window.scrollY}px`,
      );
    };

    window.addEventListener("pointermove", handleMove);
    window.addEventListener("scroll", handleScroll, { passive: true });
    handleScroll();
    return () => {
      window.removeEventListener("pointermove", handleMove);
      window.removeEventListener("scroll", handleScroll);
    };
  }, []);

  useEffect(() => {
    const activeTimeouts = flashTimeoutsRef.current;
    return () => {
      Object.values(activeTimeouts).forEach((timeoutId) => {
        window.clearTimeout(timeoutId);
      });
    };
  }, []);

  // Fetch live prices every 10s using live-price endpoints
  useEffect(() => {
    let cancelled = false;

    async function fetchLivePrices() {
      try {
        const tasks = POPULAR_STOCKS_PREVIEW.map(async (stock) => {
          const symbol = stock.apiSymbol ?? stock.symbol;
          const endpoint = `/api/v1/stocks/live-price/${encodeURIComponent(symbol)}`;
          
          try {
            const response = await fetchJsonWithFallback<{
              symbol: string;
              price: number;
              change_pct?: number;
              volume?: number;
              ts?: number;
              source?: string;
            }>(endpoint);
            
            if (response && typeof response.price === 'number') {
              return {
                sym: stock.symbol,
                name: stock.name,
                currency: stock.currency,
                exchange: stock.market === "NSE" ? "NSE" : "NYSE",
                price: response.price,
                prev: response.change_pct ? response.price / (1 + response.change_pct / 100) : response.price,
                chg: response.change_pct || 0,
                up: (response.change_pct || 0) >= 0,
                market_open: response.source === 'finnhub-ws',
              };
            }
          } catch (error) {
            console.warn(`Failed to fetch price for ${stock.symbol}:`, error);
          }
          
          // Return fallback if API fails
          return {
            sym: stock.symbol,
            name: stock.name,
            currency: stock.currency,
            exchange: stock.market === "NSE" ? "NSE" : "NYSE",
            price: 0,
            prev: 0,
            chg: 0,
            up: false,
            market_open: false,
          };
        });

        const results = await Promise.allSettled(tasks);
        const prices: Record<string, StockPrice> = {};
        const nextSparkPrices: Record<string, number> = {};
        
        results.forEach((result, index) => {
          if (result.status === 'fulfilled' && result.value) {
            const stock = POPULAR_STOCKS_PREVIEW[index];
            const priceData = result.value;
            
            prices[stock.symbol] = priceData;
            
            if (priceData.price > 0) {
              nextSparkPrices[stock.symbol] = priceData.price;
              queuePriceFlash(stock.symbol, priceData.price, livePricesRef.current[stock.symbol]?.price);
            }
          }
        });

        if (!cancelled) {
          setLivePrices(prices);
          setSparkPrices(nextSparkPrices);
        }
      } catch (error) {
        console.error("Live price fetch failed", error);
      }
    }

    void fetchLivePrices();
    const interval = window.setInterval(fetchLivePrices, 10_000);
    return () => {
      cancelled = true;
      window.clearInterval(interval);
    };
  }, [queuePriceFlash]);

  useEffect(() => {
    let cancelled = false;

    async function loadPopularPreview() {
      setPopularLoading(true);
      setPopularError(null);
      setPopularPredictions(
        POPULAR_STOCKS_PREVIEW.map((stock) => ({ ...stock, loading: true })),
      );
      try {
        const updateStock = (symbol: string, patch: Partial<PopularPrediction>) => {
          setPopularPredictions((prev) =>
            prev.map((item) => (item.symbol === symbol ? { ...item, ...patch } : item)),
          );
        };

        const tasks = POPULAR_STOCKS_PREVIEW.map(async (stock) => {
          try {
            const marketDataSymbol = stock.apiSymbol ?? stock.symbol;
            const historyUrl = `/api/v1/stocks/${encodeURIComponent(
              marketDataSymbol,
            )}/history?days=60&allow_local=false`;
            const quoteUrl = `/api/v1/stocks/${encodeURIComponent(
              marketDataSymbol,
            )}/quote?allow_local=false`;

            const quoteData = await fetchJsonWithFallback<QuoteResponse>(quoteUrl).catch(
              () => null,
            );
            const quickPrice =
              typeof quoteData?.quote?.c === "number" ? quoteData.quote.c : undefined;
            if (!cancelled && quickPrice !== undefined) {
              updateStock(stock.symbol, { price: quickPrice, loading: true });
            }

            const historyData = await fetchJsonWithFallback<HistoryResponse>(historyUrl);
            const closes = (historyData.series ?? []).map((point) => point.c);
            const lastClose =
              quickPrice ?? (closes.length ? closes[closes.length - 1] : undefined);

            if (closes.length < 2 || lastClose === undefined) {
              if (!cancelled) {
                updateStock(stock.symbol, {
                  price: lastClose,
                  signal: "HOLD",
                  loading: false,
                  error: "Not enough data",
                });
              }
              return;
            }

            const oneStep = computeBaselinePrediction(closes);
            const predictedPrice =
              oneStep !== undefined ? lastClose + (oneStep - lastClose) * 7 : lastClose;
            const changePct =
              lastClose !== 0 ? ((predictedPrice - lastClose) / lastClose) * 100 : 0;
            const trendPct = computeTrendPct(closes);
            const signal: PopularPrediction["signal"] =
              trendPct >= 0.5 || changePct >= 0.35
                ? "BUY"
                : trendPct <= -0.5 || changePct <= -0.35
                ? "SELL"
                : "HOLD";
            const confidence = Math.round(clamp(70 + Math.abs(trendPct) * 2, 18, 95));

            if (!cancelled) {
              updateStock(stock.symbol, {
                price: lastClose,
                predictedPrice,
                changePct,
                signal,
                confidence,
                loading: false,
                error: undefined,
              });
            }
          } catch (err: unknown) {
            if (!cancelled) {
              updateStock(stock.symbol, {
                signal: "HOLD",
                loading: false,
                error: err instanceof Error ? err.message : "Unable to load prediction",
              });
            }
          }
        });

        await Promise.allSettled(tasks);
      } catch (err: unknown) {
        if (!cancelled) {
          setPopularError(
            err instanceof Error ? err.message : "Unable to load popular predictions.",
          );
        }
      } finally {
        if (!cancelled) setPopularLoading(false);
      }
    }

    loadPopularPreview();
    return () => {
      cancelled = true;
    };
  }, []);

  return (
    <div className="relative min-h-screen overflow-hidden">
      <div
        className="pointer-events-none absolute -left-32 top-16 h-72 w-72 rounded-full blur-3xl parallax-layer"
        style={{
          background:
            "radial-gradient(circle, rgba(201, 130, 74, 0.3) 0%, rgba(201, 130, 74, 0) 70%)",
        }}
      />
      <div
        className="pointer-events-none absolute -right-24 top-24 h-80 w-80 rounded-full blur-3xl parallax-layer"
        style={{
          background:
            "radial-gradient(circle, rgba(234, 214, 195, 0.5) 0%, rgba(234, 214, 195, 0) 70%)",
        }}
      />
      <div
        className="pointer-events-none absolute bottom-0 left-1/2 h-64 w-64 -translate-x-1/2 rounded-full blur-3xl parallax-layer"
        style={{
          background:
            "radial-gradient(circle, rgba(255, 248, 241, 0.96) 0%, rgba(255, 248, 241, 0) 70%)",
        }}
      />

      <main className="relative mx-auto flex min-h-screen max-w-6xl flex-col gap-10 px-4 py-10 lg:py-16">
        <section className="grid grid-cols-1 gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
          <div className="space-y-6">
            <h1 className="font-display text-4xl font-semibold tracking-tight text-[var(--ink)] sm:text-5xl">
              Stock Price Prediction
            </h1>
            <p className="max-w-xl text-base text-[var(--ink-soft)] sm:text-lg">
              Predict market trends using Machine Learning & Real-Time Data.
              Experience a futuristic trading cockpit with live signals, AI
              reasoning, and actionable buy/sell strategies.
            </p>
            <div className="flex flex-wrap gap-3">
              <a
                href="/prediction"
                className="rounded-full bg-[var(--accent-strong)] px-6 py-3 text-sm font-semibold text-white shadow-md transition hover:bg-[var(--accent)]"
              >
                Predict Now
              </a>
              <a
                href="/market-news"
                className="rounded-full border border-[var(--border)] bg-white/70 px-6 py-3 text-sm font-semibold text-[var(--ink)] shadow-sm transition hover:border-[var(--accent)]"
                onClick={(event) => {
                  event.preventDefault();
                  router.push("/market-news");
                }}
              >
                Market News
              </a>
            </div>

            <div className="grid grid-cols-1 gap-4 sm:grid-cols-2">
              <div className="panel glass tilt-card p-4">
                <div className="text-xs uppercase tracking-[0.3em] text-[var(--ink-muted)]">
                  3D Stock Chart
                </div>
                <p className="mt-2 text-sm text-[var(--ink-soft)]">
                  Real-time candlestick simulation with parallax depth and
                  interactive tilt.
                </p>
              </div>
              <div className="panel glass tilt-card p-4">
                <div className="text-xs uppercase tracking-[0.3em] text-[var(--ink-muted)]">
                  AI Prediction
                </div>
                <p className="mt-2 text-sm text-[var(--ink-soft)]">
                  Clear buy/sell signals with confidence scoring and strategy
                  guidance.
                </p>
              </div>
            </div>
          </div>

          <div
            style={{
              flex: 1,
              display: "grid",
              gridTemplateColumns: "repeat(4, 1fr)",
              gap: 14,
              padding: "8px 0 8px 24px",
            }}
          >
            {[
              {
                sym: "AAPL",
                currency: "USD" as const,
                fallbackPrice: 175.43,
                fallbackChg: 1.24,
                fallbackUp: true,
              },
              {
                sym: "MSFT",
                currency: "USD" as const,
                fallbackPrice: 415.26,
                fallbackChg: -0.87,
                fallbackUp: false,
              },
              {
                sym: "RELIANCE",
                currency: "INR" as const,
                fallbackPrice: 3045.60,
                fallbackChg: 0.48,
                fallbackUp: true,
              },
              {
                sym: "TCS",
                currency: "INR" as const,
                fallbackPrice: 4156.80,
                fallbackChg: 1.12,
                fallbackUp: true,
              },
              {
                sym: "AMZN",
                currency: "USD" as const,
                fallbackPrice: 178.34,
                fallbackChg: 0.96,
                fallbackUp: true,
              },
              {
                sym: "NVDA",
                currency: "USD" as const,
                fallbackPrice: 884.92,
                fallbackChg: -0.87,
                fallbackUp: false,
              },
              {
                sym: "ITC",
                currency: "INR" as const,
                fallbackPrice: 431.8,
                fallbackChg: 0.48,
                fallbackUp: true,
              },
              {
                sym: "HDFCBANK",
                currency: "INR" as const,
                fallbackPrice: 1687.45,
                fallbackChg: 0.72,
                fallbackUp: true,
              },
            ].map((card) => {
              const live = livePrices[card.sym];
              return (
                <TickerCard
                  key={card.sym}
                  sym={card.sym}
                  price={live?.price ?? card.fallbackPrice}
                  chg={live?.chg ?? card.fallbackChg}
                  up={live?.up ?? card.fallbackUp}
                  currency={live?.currency ?? card.currency}
                  marketOpen={live?.market_open ?? false}
                />
              );
            })}
          </div>
        </section>

        <section className="panel p-6">
          <div className="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
            <div>
              <div className="text-xs uppercase tracking-[0.3em] text-[var(--ink-muted)]">
                How It Works
              </div>
              <h2 className="mt-2 font-display text-2xl text-[var(--ink)]">
                From search to signal in three steps
              </h2>
              <p className="mt-2 max-w-2xl text-sm text-[var(--ink-soft)]">
                We pull recent price history, compute AI-driven signals, and
                translate it into a clean action plan.
              </p>
            </div>
            <div className="text-xs text-[var(--ink-muted)]">Fast · Clear · Actionable</div>
          </div>

          <div className="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-3">
            {[
              {
                step: "01",
                title: "Search a Stock",
                body: "Type a symbol or company name to load live price, change, and history.",
              },
              {
                step: "02",
                title: "AI Prediction",
                body: "Our model forecasts the next 7 days and scores confidence with risk.",
              },
              {
                step: "03",
                title: "Action Plan",
                body: "Get a clear BUY/SELL signal with entry, target, stop-loss, and horizon.",
              },
            ].map((item) => (
              <div key={item.step} className="panel glass tilt-card p-4">
                <div className="text-xs font-semibold text-[var(--ink-muted)]">
                  Step {item.step}
                </div>
                <div className="mt-2 text-base font-semibold text-[var(--ink)]">
                  {item.title}
                </div>
                <p className="mt-2 text-sm text-[var(--ink-soft)]">{item.body}</p>
              </div>
            ))}
          </div>
        </section>

        <section className="panel p-6">
          <div className="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
            <div>
              <div className="text-xs uppercase tracking-[0.3em] text-[var(--ink-muted)]">
                Popular Stocks Prediction
              </div>
              <h2 className="mt-2 font-display text-2xl text-[var(--ink)]">
                Quick AI snapshot of market favorites
              </h2>
              <p className="mt-2 max-w-2xl text-sm text-[var(--ink-soft)]">
                A compact preview of the most followed stocks with live-inspired
                AI signals and 3D motion cards.
              </p>
            </div>
            <a
              href="/prediction"
              className="text-xs font-semibold uppercase tracking-[0.3em] text-[var(--accent-strong)]"
            >
              View full prediction
            </a>
          </div>

          {popularLoading && (
            <div className="mt-4 text-sm text-[var(--ink-muted)]">
              Loading popular predictions...
            </div>
          )}
          {popularError && (
            <div className="mt-4 rounded-md border border-red-500/40 bg-red-500/10 px-3 py-2 text-sm text-red-700">
              {popularError}
            </div>
          )}

          <div className="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
            {popularPredictions.map((item) => {
              const live = livePrices[item.symbol];
              const isOpen = live?.market_open ?? false;
              const sparkPrice = sparkPrices[item.symbol] ?? live?.price ?? item.price;
              const flashDirection = priceFlash[item.symbol];

              return (
                <PopularStockCard
                  key={item.symbol}
                  item={item}
                  live={live}
                  isOpen={isOpen}
                  sparkPrice={sparkPrice}
                  flashDirection={flashDirection}
                />
              );
            })}
          </div>
        </section>
      </main>
    </div>
  );
}
