#
# Copy to `.env` and fill values:
#   cp .env.example .env
#
# Secrets
JWT_SECRET_KEY=change-me-use-a-long-random-string

# Backend CORS (JSON array of allowed origins)
BACKEND_CORS_ORIGINS=["http://localhost","http://127.0.0.1","http://localhost:3000","http://127.0.0.1:3000","http://localhost:80","http://127.0.0.1:80"]

# Data stores (Docker Compose defaults use internal hostnames)
POSTGRES_DSN=postgresql+psycopg2://postgres:postgres@postgres:5432/stocks
MONGO_DSN=mongodb://mongo:27017/stocks
REDIS_URL=redis://redis:6379/0

# Market data providers
FINNHUB_API_KEY=your_finnhub_key
ALPHAVANTAGE_API_KEY=your_alpha_vantage_key
ALPHAVANTAGE_INR_SUFFIX=.BSE

# Anthropic (for /api/chat proxy)
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Feature flags
LOCAL_DATA_ONLY=0

# Firebase Authentication
# Get these from Firebase Console > Project Settings > General
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=your_firebase_client_email

# Frontend -> backend base URL
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8001

# Firebase Frontend Configuration
# Get these from Firebase Console > Project Settings > General > Your apps
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
